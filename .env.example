# 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 阿里云百炼API配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 服务器配置
HOST=0.0.0.0
PORT=8000

# TTS模型配置
MODEL_PATH=./voice/zh_CN-huayan-medium.onnx

# WebSocket配置
WS_HOST=localhost
WS_PORT=8765

# 音频配置
AUDIO_SAMPLE_RATE=24000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1024

# 日志配置
LOG_LEVEL=INFO