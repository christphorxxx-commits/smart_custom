{
    "_id": ObjectId("69dca6647d321630360ce492"),
    "app_id": "8488bff8-30a2-415d-8d1d-7c4fb4b6567b",
    "name": "智能分类创作",
    "description": "根据用户输入自动分类，选择不同类型生成故事/笑话/诗歌",
    "icon": "🤖",
    "nodes": [
        {
            "id": "start",
            "type": "start"
        },
        {
            "id": "router",
            "type": "router",
            "config": {
                "options": [
                    "story",
                    "joke",
                    "poem"
                ]
            }
        },
        {
            "id": "story_node",
            "type": "llm",
            "config": {
                "prompt": "写一个故事：{input}"
            }
        },
        {
            "id": "joke_node",
            "type": "llm",
            "config": {
                "prompt": "讲一个笑话：{input}"
            }
        },
        {
            "id": "poem_node",
            "type": "llm",
            "config": {
                "prompt": "写一首诗：{input}"
            }
        }
    ],
    "edges": [
        {
            "source": "start",
            "target": "router",
            "type": "normal"
        },
        {
            "source": "router",
            "target": "story_node",
            "type": "conditional",
            "condition": "story"
        },
        {
            "source": "router",
            "target": "joke_node",
            "type": "conditional",
            "condition": "joke"
        },
        {
            "source": "router",
            "target": "poem_node",
            "type": "conditional",
            "condition": "poem"
        },
        {
            "source": "story_node",
            "target": "end",
            "type": "normal"
        },
        {
            "source": "joke_node",
            "target": "end",
            "type": "normal"
        },
        {
            "source": "poem_node",
            "target": "end",
            "type": "normal"
        }
    ],
    "is_public": false
}
